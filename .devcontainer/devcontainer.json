{
  // Dev container for the AI-in-science workshop.
  //
  // This points at a PREBUILT image — rocker tidyverse + Quarto + the exercise R
  // packages, all baked in — so Codespaces launch fast (just an image pull, no
  // build/installs at launch). The image is built & pushed by
  // `scripts/build-image.sh` (or the GitHub Actions workflow) from
  // `.devcontainer/Dockerfile`. After editing the Dockerfile, re-run that script
  // and the new image is live for everyone.
  //
  // IMPORTANT: the image must exist and be PUBLIC on GHCR before Codespaces from
  // this repo (or copies of it) will work. If you need to build-on-launch instead
  // (no prebuilt image yet — slower), replace the "image" line with:
  //     "build": { "dockerfile": "Dockerfile" }
  "name": "ai-in-science-workshop",
  "image": "ghcr.io/plant-success/ai-in-science-workshop:latest",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "REditorSupport.r",
        "quarto.quarto",
        "ritwickdey.LiveServer"
      ],
      "settings": {
        "editor.formatOnSave": false,
        "files.eol": "\n",
        // reduce first-launch modal friction for workshop participants
        "security.workspace.trust.enabled": false,
        "chat.agent.enabled": true
      }
    }
  }

  // Tip: 2-core is plenty here. To force 4-core for everyone, add:
  //   "hostRequirements": { "cpus": 4 }
}
